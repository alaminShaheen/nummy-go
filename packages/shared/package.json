{
  "name": "@nummygo/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, Zod schemas, shadcn/ui components, and Drizzle DB queries for NummyGo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    },
    "./db-queries": {
      "types": "./dist/db-queries/index.d.ts",
      "default": "./dist/db-queries/index.js"
    },
    "./db-queries/schema": {
      "types": "./dist/db-queries/schema.d.ts",
      "default": "./dist/db-queries/schema.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "drizzle-orm": "^0.38.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  }
}
