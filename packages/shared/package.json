{
  "name": "@nummygo/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared models, Zod schemas, shadcn/ui components, and Drizzle DB layer for NummyGo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./models/enums": {
      "types": "./dist/models/enums.d.ts",
      "default": "./dist/models/enums.js"
    },
    "./models/types": {
      "types": "./dist/models/types/index.d.ts",
      "default": "./dist/models/types/index.js"
    },
    "./models/dtos": {
      "types": "./dist/models/dtos/index.d.ts",
      "default": "./dist/models/dtos/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "default": "./dist/db/schema/index.js"
    },
    "./db/queries": {
      "types": "./dist/db/queries/index.d.ts",
      "default": "./dist/db/queries/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "lucide-react": "^1.7.0",
    "tailwind-merge": "^2.6.1",
    "ulidx": "^2.4.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@types/react": "^19.0.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
