# Environment variables for local development with Wrangler
# Copy this file to .dev.vars and fill in your values
# .dev.vars is automatically loaded by Wrangler and should not be committed to git

# Example environment variables
# ENVIRONMENT=development
# API_KEY=your-api-key-here
# DATABASE_URL=your-database-url

# Note: For bindings like KV, D1, R2, etc., configure them in wrangler.toml
