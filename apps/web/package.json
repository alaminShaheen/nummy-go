    "@types/react-dom": "^19.0.0",
    "api-worker": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "typescript": "^5.0.0",
    "vercel": "^50.39.0",
    "wrangler": "^4.80.0"
  },
  "packageManager": "pnpm@10.33.0"
}
