{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",

    "build:manual:staging": "dotenv -e .env.staging -- opennextjs-cloudflare build",
    "deploy:manual:staging": "pnpm build:manual:staging && opennextjs-cloudflare deploy --env staging",

    "build:cf:staging": "opennextjs-cloudflare build",
    "deploy:cf:staging": "opennextjs-cloudflare deploy --env staging",

    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@nummygo/shared": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.1.6",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "superjson": "^2.2.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
