{
	"name": "web",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port 3000",
		"build": "next build",
		"build:manual:staging": "dotenv -e .env.staging -- opennextjs-cloudflare build",
		"deploy:manual:staging": "pnpm build:manual:staging && opennextjs-cloudflare deploy --env staging",
		"build:manual:prod": "dotenv -e .env.production -- opennextjs-cloudflare build",
		"deploy:manual:prod": "pnpm build:manual:prod && opennextjs-cloudflare deploy --env production",
		"build:cf:staging": "dotenv -e .env.staging -- opennextjs-cloudflare build",
		"deploy:cf:staging": "opennextjs-cloudflare deploy --env staging",
		"build:cf:prod": "dotenv -e .env.production -- opennextjs-cloudflare build",
		"deploy:cf:prod": "opennextjs-cloudflare deploy --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@hookform/resolvers": "^5.2.2",
		"@nummygo/shared": "workspace:*",
		"@tailwindcss/postcss": "^4.2.2",
		"@tanstack/react-query": "^5.0.0",
		"@tanstack/react-table": "^8.21.3",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@trpc/server": "^11.0.0",
		"better-auth": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"leaflet": "^1.9.4",
		"lucide-react": "^1.7.0",
		"next": "^15.1.6",
		"next-themes": "^0.4.6",
		"postcss": "^8.5.8",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.72.1",
		"react-leaflet": "^5.0.0",
		"shadcn": "^4.1.2",
		"sonner": "^2.0.7",
		"superjson": "^2.2.2",
		"tailwind-merge": "^2.6.1",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@opennextjs/cloudflare": "^1.18.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^22.15.19",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"api-worker": "workspace:*",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.2.2",
		"typescript": "^5.9.2",
		"vercel": "^50.39.0",
		"wrangler": "^4.80.0"
	},
	"packageManager": "pnpm@10.33.0"
}
