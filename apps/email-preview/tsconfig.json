{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "skipLibCheck": true,
    "paths": {
      "@nummygo/shared": ["../../packages/shared/src/index.ts"],
      "@nummygo/shared/*": ["../../packages/shared/src/*"]
