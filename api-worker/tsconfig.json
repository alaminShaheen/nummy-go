{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Cloudflare Workers run in a non-Node environment.
    // Using "webworker" + CF types gives correct globals (fetch, Request, etc.)
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    // No output directory – Wrangler bundles directly from source
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
