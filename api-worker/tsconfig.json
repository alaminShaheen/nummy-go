{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Cloudflare Workers run in a non-Node environment.
    // Using "webworker" + generated types (worker-configuration.d.ts)
    "lib": ["ES2022", "WebWorker"],
    // No output directory – Wrangler bundles directly from source
    "noEmit": true
  },
  "include": ["src/**/*", "worker-configuration.d.ts"],
  "exclude": ["node_modules"]
}
