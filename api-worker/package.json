{
  "name": "api-worker",
  "version": "1.0.0",
  "private": true,
  "description": "NummyGo Cloudflare Worker – tRPC API + Durable Objects for real-time order updates",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/trpc/routers/_app.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types --env-interface Env"
  },
  "dependencies": {
    "@nummygo/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "zod": "^3.24.1",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.9.2",
    "wrangler": "^3.86.1"
  }
}
