{
  "name": "api-worker",
  "version": "1.0.0",
  "private": true,
  "description": "nummyGo Cloudflare Worker – tRPC API + Durable Objects for real-time order updates",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/trpc/routers/_app.ts"
    }
  },
  "scripts": {
    "dev": "pnpm run cf-typegen && wrangler dev --port 8787 --env local",
    "build": "tsc",
    "generate": "drizzle-kit generate",
    "cf-typegen": "wrangler types --env-interface Env",
    
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "better-auth generate --config src/auth.cli.ts",

    "migrate:local": "wrangler d1 migrations apply nummygo-db-dev --remote --env local",
    "migrate:staging": "wrangler d1 migrations apply nummygo-db-staging --remote --env staging",
    "migrate:prod": "wrangler d1 migrations apply nummygo-db-staging --remote --env production",
    
    "nuke:tenant": "./scripts/nuke-tenant.sh",
    "nuke:tenant:prod": "./scripts/nuke-tenant.sh --env production"
  },
  "dependencies": {
    "@nummygo/shared": "workspace:*",
    "@react-email/render": "^2.0.6",
    "@trpc/server": "^11.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.5.6",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.41.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "resend": "^6.10.0",
    "ulidx": "^2.4.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@libsql/client": "^0.17.2",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2",
    "wrangler": "^4.80.0"
  }
}
